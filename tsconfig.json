{
	"include": [
		"./src",
		"./test",
		"./demo/src"
	],
	"compilerOptions": {
		// File Layout
		"rootDir": ".",
		"outDir": "./dist",
		// Environment Settings
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "es2025",
		"types": ["node"],
		// Style Options
		"noImplicitReturns": true,
		"noImplicitOverride": true,
		// Other
		"allowSyntheticDefaultImports": true,
		"noUncheckedSideEffectImports": true,
		"resolveJsonModule": true,
		"sourceMap": false,
		"skipLibCheck": true
	}
}
